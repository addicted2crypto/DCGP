    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "typescript": "~5.6.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  }
}
